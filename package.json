{
  "name": "look-inventory",
  "version": "1.0.0",
  "description": "Offline-first inventory + billing PWA for small rural shops",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "npx http-server -p 8080 -c-1 .",
    "build": "node tools/build.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:install": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "http-server": "^14.1.1",
    "javascript-obfuscator": "^4.1.1",
    "terser": "^5.31.0"
  }
}
